# .env  —  copy to .env and fill in real values
APP_NAME="Pi OS API"
DEBUG=false
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://pios:password@db:5432/pios
DATABASE_URL_SYNC=postgresql+psycopg2://pios:Pwd%40123@db:5432/pios
DATABASE_PASSWORD=Pwd@123
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=pios
DATABASE_USER=pios

SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Must be exactly 32 bytes
ENCRYPTION_KEY=change-me-32-byte-key-for-aes256!

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://pi-osq.com"]

DEFAULT_MAX_DRAWDOWN_PCT=15.0
DEFAULT_DAILY_LOSS_LIMIT=5000.0
DEFAULT_MAX_POSITION_USD=20000.0
DEFAULT_MAX_LEVERAGE=3.0
